# Copy this file to android/keystore.properties and fill in real values.
# Do NOT commit android/keystore.properties or your keystore file.

# Path can be absolute or relative to the android/ folder.
storeFile=/absolute/path/to/your-release-key.jks
storePassword=CHANGE_ME_STORE_PASSWORD
keyAlias=CHANGE_ME_KEY_ALIAS
keyPassword=CHANGE_ME_KEY_PASSWORD

